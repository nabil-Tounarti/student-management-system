# Docker Environment Configuration for Student Management System
# Copy this file to .env.docker and update the secrets for production use

# =============================================================================
# SECURITY SECRETS - CHANGE THESE IN PRODUCTION!
# =============================================================================

# JWT Secrets - Use strong, random strings (at least 32 characters)
JWT_ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_change_in_production_32chars
JWT_REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_change_in_production_32chars

# CSRF Secret
CSRF_TOKEN_SECRET=your_csrf_secret_key_change_in_production_32chars

# Email Verification Secret
EMAIL_VERIFICATION_TOKEN_SECRET=your_email_verification_secret_change_in_prod_32chars

# Password Setup Secret
PASSWORD_SETUP_TOKEN_SECRET=your_password_setup_secret_change_in_prod_32chars

# =============================================================================
# EMAIL CONFIGURATION (Optional - for password reset functionality)
# =============================================================================

# Resend API Key - Get from https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Sender email address
MAIL_FROM_USER=noreply@school.com

# =============================================================================
# ADVANCED CONFIGURATION (Optional)
# =============================================================================

# Token expiration times (in milliseconds)
# JWT_ACCESS_TOKEN_TIME_IN_MS=900000
# JWT_REFRESH_TOKEN_TIME_IN_MS=28800000
# CSRF_TOKEN_TIME_IN_MS=950000
# EMAIL_VERIFICATION_TOKEN_TIME_IN_MS=18000000
# PASSWORD_SETUP_TOKEN_TIME_IN_MS=300000
